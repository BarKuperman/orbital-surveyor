{
  "name": "orbital-surveyor",
  "version": "1.1.2",
  "description": "Satellite, railway, and terrain overlays for Subway Builder via a local tile proxy",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "pnpm build:mod && pnpm build:proxy",
    "build:mod": "vite build",
    "build:proxy": "vite build --config vite.proxy.config.ts",
    "check:artifacts": "node scripts/check-provider-artifacts.mjs",
    "dev": "concurrently -k -n build,game -c blue,green \"vite build --watch\" \"tsx scripts/run.ts\"",
    "dev:link": "tsx scripts/link.ts",
    "dev:unlink": "tsx scripts/link.ts --unlink",
    "proxy": "tsx proxy.js",
    "test": "tsx --test tests/providers.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "subway-builder",
    "mod"
  ],
  "author": "barku",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.9",
    "concurrently": "^9.2.1",
    "maplibre-gl": "^5.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vite-plugin-static-copy": "^3.0.0"
  }
}
